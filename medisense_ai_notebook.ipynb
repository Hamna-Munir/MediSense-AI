    "---\n",
    "## 6. Demo: Live Triage Examples <a id='6-demo'></a>\n",
    "\n",
    "We test MediSense across **five patient cases** spanning all four triage levels — from a mild cold to a potential myocardial infarction.\n"
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "display-util-cell",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Pretty-print helper ───────────────────────────────────────────────────\n",
    "\n",
    "def display_result(case: PatientCase, result: TriageResult, case_name: str = \"\"):\n",
    "    \"\"\"Render a triage result as styled HTML in the notebook.\"\"\"\n",
    "\n",
    "    conditions_html = \"\".join(\n",
    "        f'<span style=\"background:#261319;border:1px solid #4d2030;border-radius:6px;'\n",
    "        f'padding:4px 10px;font-size:12px;margin:3px;display:inline-block;color:#b07080;\">'\n",
    "        f'{c}</span>' for c in result.conditions\n",
    "    )\n",
    "\n",
    "    urgent_html = \"\"\n",
    "    if result.urgent:\n",
    "        urgent_html = f\"\"\"\n",
    "        <div style=\"background:rgba(255,45,85,0.1);border:1px solid rgba(255,45,85,0.35);\n",
    "                    border-radius:10px;padding:14px;margin-top:12px;color:#ff2d55;\n",
    "                    font-weight:600;font-size:13px;\">\n",
    "            🚨 {result.urgent}\n",
    "        </div>\"\"\"\n",
    "\n",
    "    steps_html    = result.steps.replace(\"\\n\", \"<br>\")\n",
    "    redflags_html = result.red_flags.replace(\"\\n\", \"<br>\")\n",
    "\n",
    "    html = f\"\"\"\n",
    "    <div style=\"font-family: 'Segoe UI', sans-serif; background:#0d0608;\n",
    "                border:1px solid #3a1a22; border-radius:16px;\n",
    "                padding:24px; margin:16px 0; color:#ffe8ef;\">\n",
    "\n",
    "      <!-- Header -->\n",
    "      <div style=\"display:flex;align-items:center;justify-content:space-between;\n",
    "                  border-bottom:1px solid #3a1a22;padding-bottom:14px;margin-bottom:18px;\">\n",
    "        <div>\n",
    "          <div style=\"font-size:11px;color:#5a3040;letter-spacing:2px;\n",
    "                      text-transform:uppercase;margin-bottom:4px;\">CASE</div>\n",
    "          <div style=\"font-size:16px;font-weight:700;color:#ffe8ef;\">{case_name}</div>\n",
    "        </div>\n",
    "        <div style=\"background:rgba(255,77,141,0.08);border:1px solid {result.color}44;\n",
    "                    border-radius:24px;padding:8px 18px;display:flex;\n",
    "                    align-items:center;gap:8px;\">\n",
    "          <span style=\"font-size:14px;\">{result.emoji}</span>\n",
    "          <span style=\"color:{result.color};font-weight:700;font-size:13px;\">\n",
    "            {result.triage_label}\n",
    "          </span>\n",
    "        </div>\n",
    "      </div>\n",
    "\n",
    "      <!-- Latency badge -->\n",
    "      <div style=\"font-size:10px;color:#5a3040;margin-bottom:16px;\">\n",
    "        ⚡ Response time: {result.latency_ms:.0f}ms\n",
    "      </div>\n",
    "\n",
    "      <!-- Summary -->\n",
    "      <div style=\"margin-bottom:16px;\">\n",
    "        <div style=\"font-size:9px;letter-spacing:2px;text-transform:uppercase;\n",
    "                    color:#ff4d8d;margin-bottom:8px;font-weight:700;\">Clinical Summary</div>\n",
    "        <div style=\"font-size:13px;line-height:1.8;color:#b07080;\">{result.summary}</div>\n",
    "      </div>\n",
    "\n",
    "      <!-- Conditions -->\n",
    "      <div style=\"margin-bottom:16px;\">\n",
    "        <div style=\"font-size:9px;letter-spacing:2px;text-transform:uppercase;\n",
    "                    color:#ff4d8d;margin-bottom:8px;font-weight:700;\">Possible Conditions</div>\n",
    "        <div>{conditions_html}</div>\n",
    "      </div>\n",
    "\n",
    "      <!-- 2-col grid -->\n",
    "      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;\">\n",
    "        <div style=\"background:#160b0e;border:1px solid #3a1a22;border-radius:10px;padding:14px;\">\n",
    "          <div style=\"font-size:9px;letter-spacing:2px;text-transform:uppercase;\n",
