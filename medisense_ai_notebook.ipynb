    "# ── Run All Cases & Display Results ──────────────────────────────────────\n",
    "\n",
    "results_log = []   # Store for analysis later\n",
    "\n",
    "for case_name, patient_case in test_cases:\n",
    "    print(f\"\\n⏳ Triaging: {case_name}...\")\n",
    "    try:\n",
    "        result = engine.triage(patient_case)\n",
    "        display_result(patient_case, result, case_name)\n",
    "        results_log.append({\n",
    "            \"case\"        : case_name,\n",
    "            \"triage\"      : result.triage,\n",
    "            \"label\"       : result.triage_label,\n",
    "            \"conditions\"  : \", \".join(result.conditions),\n",
    "            \"severity_in\" : patient_case.severity,\n",
    "            \"latency_ms\"  : result.latency_ms,\n",
    "            \"has_urgent\"  : bool(result.urgent)\n",
    "        })\n",
    "    except Exception as e:\n",
    "        print(f\"  ❌ Error: {e}\")\n",
    "    time.sleep(0.5)  # Respect rate limits"
   ]
